# Gemma4NPC — Environment Variables
# Copy this file to .env and fill in your keys

# HuggingFace (required for model download and dataset upload)
HF_TOKEN=your_huggingface_token

# Weights & Biases (required for training experiment tracking)
WANDB_API_KEY=your_wandb_key

# Google Gemini (required for NPC_dialogue_v2 generation)
GEMINI_API_KEY=your_gemini_api_key

# OpenAI (optional — only for PIPPA content moderation filtering)
OPENAI_API_KEY=your_openai_api_key_for_moderation

# Anthropic (optional — only for DPO preference pair judging)
ANTHROPIC_API_KEY=your_anthropic_api_key

# HuggingFace Dataset Repository
HF_DATASET_REPO=chimbiwide/RolePlay-NPC-v2

# HuggingFace Model Repository (change to your username)
HF_MODEL_REPO=chimbiwide/Gemma4NPC-it
